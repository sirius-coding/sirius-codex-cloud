# 基础配置
APP_NAME=freelance-template
ENV=dev
PORT=8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# 数据库配置（容器内连接）
DATABASE_URL=sqlite:///./data/freelance.db

# 安全配置
API_TOKEN=replace-with-your-token

# Python API 通用覆盖（按需在子项目目录或启动命令里覆盖）
# DATABASE_URL=sqlite:///./data/app.db

# 爬虫服务（apps/web-crawler）
CRAWLER_URL=https://example.com
CRAWLER_MAX_PAGES=10
CRAWLER_INTERVAL_SECONDS=0
CRAWLER_USER_AGENT=sirius-codex-crawler/1.0 (+https://localhost)

# China Commerce Starter（apps/china-commerce-starter）
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/china_commerce?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SERVER_PORT=8080
